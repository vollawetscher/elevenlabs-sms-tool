# ElevenLabs SMS Tool Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# seven.io SMS API Configuration
SEVEN_IO_API_KEY=your_seven_io_api_key_here
SMS_SENDER_ID=KFZ-Service

# Security
CLEANUP_TOKEN=your_random_cleanup_token_here

# Optional: Database (for production)
# DATABASE_URL=postgresql://user:password@host:port/database

# Optional: Redis (for production session storage)
# REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info