<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{service.title}} - Ihre persönliche Unterlagenliste</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            background: #f8fafc;
            padding: 20px;
        }
        
        .container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        
        .header {
            background: linear-gradient(135deg, #1e40af 0%, #3b82f6 50%, #06b6d4 100%);
            color: white;
            padding: 40px 30px;
            text-align: center;
            position: relative;
        }
        
        .header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse"><path d="M 10 0 L 0 0 0 10" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/></pattern></defs><rect width="100" height="100" fill="url(%23grid)"/></svg>') repeat;
            opacity: 0.3;
        }
        
        .header-content {
            position: relative;
            z-index: 1;
        }
        
        .header h1 {
            font-size: 28px;
            margin-bottom: 10px;
            font-weight: 700;
        }
        
        .header p {
            opacity: 0.9;
            font-size: 16px;
            font-weight: 300;
        }
        
        .conversation-badge {
            display: inline-block;
            background: rgba(255, 255, 255, 0.2);
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 14px;
            margin-top: 10px;
            backdrop-filter: blur(10px);
        }
        
        .generated-info {
            background: #f1f5f9;
            padding: 20px 30px;
            border-left: 4px solid #3b82f6;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }
        
        .generated-info .info-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: #64748b;
        }
        
        .content {
            padding: 40px 30px;
        }
        
        .section {
            margin-bottom: 40px;
        }
        
        .section h2 {
            color: #1e293b;
            font-size: 22px;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #e2e8f0;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .section-icon {
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #3b82f6;
            color: white;
            border-radius: 6px;
            font-size: 14px;
        }
        
        .document-grid {
            display: grid;
            gap: 15px;
        }
        
        .document-item {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 20px;
            display: flex;
            align-items: flex-start;
            gap: 15px;
            transition: all 0.2s ease;
            position: relative;
        }
        
        .document-item:hover {
            border-color: #3b82f6;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.1);
        }
        
        .checkbox-container {
            position: relative;
            margin-top: 2px;
        }
        
        .checkbox {
            width: 20px;
            height: 20px;
            border: 2px solid #10b981;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.2s ease;
            position: relative;
        }
        
        .checkbox:hover {
            border-color: #059669;
            background: #f0fdf4;
        }
        
        .checkbox.checked {
            background: #10b981;
            border-color: #10b981;
        }
        
        .checkbox.checked::after {
            content: '✓';
            position: absolute;
            color: white;
            font-size: 14px;
            top: -2px;
            left: 2px;
        }
        
        .document-text {
            flex: 1;
            font-size: 15px;
            line-height: 1.5;
        }
        
        .office-card {
            background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px;
        }
        
        .office-header {
            margin-bottom: 20px;
        }
        
        .office-name {
            font-size: 20px;
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 5px;
        }
        
        .office-details {
            display: grid;
            gap: 12px;
        }
        
        .office-detail {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
        }
        
        .detail-icon {
            width: 32px;
            height: 32px;
            background: #3b82f6;
            color: white;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }
        
        .cost-card {
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            border: 1px solid #f59e0b;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px;
        }
        
        .cost-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }
        
        .cost-label {
            font-weight: 600;
            color: #92400e;
        }
        
        .cost-value {
            color: #1f2937;
        }
        
        .notes-card {
            background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
            border: 1px solid #3b82f6;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px;
        }
        
        .privacy-notice {
            background: #f0f9ff;
            border: 1px solid #0ea5e9;
            border-radius: 12px;
            padding: 25px;
            font-size: 14px;
            line-height: 1.6;
        }
        
        .privacy-title {
            font-weight: 600;
            color: #0c4a6e;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .footer {
            background: #1e293b;
            color: white;
            padding: 30px;
            text-align: center;
        }
        
        .footer-content {
            margin-bottom: 20px;
        }
        
        .footer-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 10px;
        }
        
        .session-info {
            font-size: 12px;
            color: #94a3b8;
            font-family: 'Monaco', 'Menlo', monospace;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 20px;
            margin: 20px 0;
            text-align: center;
        }
        
        .stat-item {
            background: rgba(255, 255, 255, 0.1);
            padding: 15px;
            border-radius: 8px;
        }
        
        .stat-number {
            font-size: 24px;
            font-weight: 700;
            color: #3b82f6;
        }
        
        .stat-label {
            font-size: 12px;
            color: #64748b;
            margin-top: 5px;
        }
        
        /* Print styles */
        @media print {
            body {
                background: white;
                padding: 0;
            }
            
            .container {
                box-shadow: none;
                border-radius: 0;
            }
            
            .header {
                background: #1e40af !important;
                -webkit-print-color-adjust: exact;
            }
            
            .section {
                page-break-inside: avoid;
            }
            
            .document-item {
                border: 1px solid #ccc !important;
                background: #f9f9f9 !important;
            }
        }
        
        /* Mobile responsive */
        @media (max-width: 600px) {
            body {
                padding: 10px;
            }
            
            .content {
                padding: 20px 15px;
            }
            
            .header {
                padding: 30px 20px;
            }
            
            .header h1 {
                font-size: 24px;
            }
            
            .generated-info {
                flex-direction: column;
                gap: 10px;
                align-items: flex-start;
            }
            
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <div class="header-content">
                <h1>{{service.title}}</h1>
                <p>{{service.description}}</p>
                <div class="conversation-badge">
                    📞 Aus Ihrem Gespräch extrahiert
                </div>
            </div>
        </div>
        
        <!-- Generated Info -->
        <div class="generated-info">
            <div class="info-item">
                <span>📅</span>
                <span>Erstellt: {{createdAt}}</span>
            </div>
            <div class="info-item">
                <span>📋</span>
                <span>{{documentsCount}} Dokumente</span>
            </div>
            <div class="info-item">
                <span>⏰</span>
                <span>Gültig bis: {{expiresAt}}</span>
            </div>
        </div>
        
        <!-- Content -->
        <div class="content">
            <!-- Office Information -->
            {{#if office.name}}
            <div class="section">
                <h2>
                    <div class="section-icon">🏛️</div>
                    Ihr Ansprechpartner
                </h2>
                <div class="office-card">
                    <div class="office-header">
                        <div class="office-name">{{office.name}}</div>
                    </div>
                    
                    <div class="office-details">
                        {{#if office.address}}
                        <div class="office-detail">
                            <div class="detail-icon">📍</div>
                            <span>{{office.address}}</span>
                        </div>
                        {{/if}}
                        
                        {{#if office.phone}}
                        <div class="office-detail">
                            <div class="detail-icon">📞</div>
                            <span>{{office.phone}}</span>
                        </div>
                        {{/if}}
                        
                        {{#if office.hours}}
                        <div class="office-detail">
                            <div class="detail-icon">🕒</div>
                            <span>{{office.hours}}</span>
                        </div>
                        {{/if}}
                        
                        {{#if office.website}}
                        <div class="office-detail">
                            <div class="detail-icon">🌐</div>
                            <span>{{office.website}}</span>
                        </div>
                        {{/if}}
                    </div>
                </div>
            </div>
            {{/if}}
            
            <!-- Required Documents -->
            <div class="section">
                <h2>
                    <div class="section-icon">📋</div>
                    Benötigte Unterlagen
                </h2>
                <p style="margin-bottom: 25px; color: #64748b; font-style: italic;">
                    Diese Liste basiert auf den spezifischen Informationen aus Ihrem Gespräch:
                </p>
                
                <div class="document-grid">
                    {{#each documents}}
                    <div class="document-item">
                        <div class="checkbox-container">
                            <div class="checkbox" onclick="toggleCheck(this)"></div>
                        </div>
                        <div class="document-text">{{this}}</div>
                    </div>
                    {{/each}}
                </div>
            </div>
            
            <!-- Cost Information -->
            {{#if cost}}
            <div class="section">
                <h2>
                    <div class="section-icon">💰</div>
                    Kosten & Zahlung
                </h2>
                <div class="cost-card">
                    {{#if cost.cost}}
                    <div class="cost-item">
                        <span class="cost-label">Gebühr:</span>
                        <span class="cost-value">{{cost.cost}}</span>
                    </div>
                    {{/if}}
                    
                    {{#if cost.paymentMethods}}
                    <div class="cost-item">
                        <span class="cost-label">Zahlung:</span>
                        <span class="cost-value">{{cost.paymentMethods}}</span>
                    </div>
                    {{/if}}
                </div>
            </div>
            {{/if}}
            
            <!-- Additional Notes -->
            {{#if additionalNotes}}
            <div class="section">
                <h2>
                    <div class="section-icon">📝</div>
                    Wichtige Hinweise
                </h2>
                <div class="notes-card">
                    <p>{{additionalNotes}}</p>
                </div>
            </div>
            {{/if}}
            
            <!-- Privacy Notice -->
            <div class="section">
                <h2>
                    <div class="section-icon">🔒</div>
                    Datenschutzhinweis (DSGVO)
                </h2>
                <div class="privacy-notice">
                    <div class="privacy-title">
                        <span>🔐</span>
                        Ihre Daten sind geschützt
                    </div>
                    <p>
                        <strong>Datenverarbeitung:</strong> Ihre Telefonnummer wurde temporär gespeichert, 
                        um Ihnen diesen personalisierten Link zu senden, und wird innerhalb von 48 Stunden automatisch gelöscht.
                    </p>
                    <p style="margin-top: 10px;">
                        <strong>Gültigkeit:</strong> Diese Seite läuft am {{expiresAt}} ab und wird automatisch entfernt.
                    </p>
                    <p style="margin-top: 10px;">
                        <strong>Ihre Rechte:</strong> Sie haben das Recht auf Auskunft, Berichtigung und Löschung 
                        Ihrer Daten. Bei Fragen wenden Sie sich an die jeweilige Zulassungsstelle.
                    </p>
                    <p style="margin-top: 10px;">
                        <strong>Personalisierte Inhalte:</strong> Diese Unterlagenliste wurde basierend auf Ihrem 
                        spezifischen Gespräch erstellt und spiegelt die individuell besprochenen Anforderungen wider.
                    </p>
                </div>
            </div>
        </div>
        
        <!-- Footer -->
        <div class="footer">
            <div class="footer-content">
                <div class="footer-title">Digitaler Assistent der KFZ-Zulassungsstelle</div>
                <p style="font-size: 14px; opacity: 0.8; margin-bottom: 20px;">
                    Personalisierte Dokumentenliste basierend auf Ihrem Gespräch
                </p>
                
                <div class="stats-grid">
                    <div class="stat-item">
                        <div class="stat-number">{{documentsCount}}</div>
                        <div class="stat-label">Dokumente</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">7</div>
                        <div class="stat-label">Tage gültig</div>
                    </div>
                </div>
            </div>
            
            <div class="session-info">
                Session: {{sessionId}} | Erstellt: {{createdAt}}
            </div>
        </div>
    </div>
    
    <script>
        function toggleCheck(checkbox) {
            checkbox.classList.toggle('checked');
            
            // Save checked state to localStorage for this session
            const sessionId = '{{sessionId}}';
            const checkboxes = document.querySelectorAll('.checkbox');
            const checkedStates = Array.from(checkboxes).map(cb => cb.classList.contains('checked'));
            localStorage.setItem('checklist_' + sessionId, JSON.stringify(checkedStates));
        }
        
        // Load saved checkbox states
        document.addEventListener('DOMContentLoaded', function() {
            const sessionId = '{{sessionId}}';
            const saved = localStorage.getItem('checklist_' + sessionId);
            
            if (saved) {
                const checkedStates = JSON.parse(saved);
                const checkboxes = document.querySelectorAll('.checkbox');
                
                checkboxes.forEach((checkbox, index) => {
                    if (checkedStates[index]) {
                        checkbox.classList.add('checked');
                    }
                });
            }
        });
        
        // Print functionality
        function printDocument() {
            window.print();
        }
        
        // Add print button if needed
        if (window.matchMedia && window.matchMedia('(min-width: 768px)').matches) {
            const printBtn = document.createElement('button');
            printBtn.innerHTML = '🖨️ Drucken';
            printBtn.style.cssText = 'position: fixed; top: 20px; right: 20px; background: #3b82f6; color: white; border: none; padding: 10px 15px; border-radius: 8px; cursor: pointer; z-index: 1000; font-size: 14px;';
            printBtn.onclick = printDocument;
            document.body.appendChild(printBtn);
        }
    </script>
</body>
</html>
